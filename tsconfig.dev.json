{
  "compilerOptions": {
    "target": "es2020",
    "module": "es2020",
    "outDir": "./tmp/js",
    "rootDir": "./src/ts/",
    "strict": true,
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["./src/ts/*.ts"],
  "exclude": ["node_modules", "./tmp/js/*.js"]
}
